{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "mkdir -p public && cp -r frontend/* public/",
  "outputDirectory": "public",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "data/customers.db"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api).)*",
      "destination": "/index.html"
    }
  ]
}
