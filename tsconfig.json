{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "api/**/*.ts",
    "backend/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ]
}
